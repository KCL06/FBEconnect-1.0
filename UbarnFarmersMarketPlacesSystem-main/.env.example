# FBEconnect Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE:
#   1. Copy this file to .env  →  cp .env.example .env
#   2. Fill in the values from your Supabase project dashboard.
#   3. Restart the dev server after changing values.
#
# ─────────────────────────────────────────────────────────────────────────────
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │                     PUBLIC / FRONTEND VARIABLES                         │
# │                                                                         │
# │  Prefixed with VITE_ — these are embedded in the browser bundle.        │
# │  They are NOT secrets. Security is enforced by Supabase RLS policies.   │
# └──────────────────────────────────────────────────────────────────────────┘

# Supabase Project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=

# Supabase Anonymous / Public Key (Settings → API → anon / public)
VITE_SUPABASE_ANON_KEY=

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                   PRIVATE / SERVER-SIDE SECRETS                         │
# │                                                                         │
# │  ⚠️  NEVER prefix these with VITE_ — they must NOT appear in the       │
# │      browser bundle. Use only in Supabase Edge Functions, Vercel        │
# │      serverless functions, or backend services.                         │
# └──────────────────────────────────────────────────────────────────────────┘

# SUPABASE_SERVICE_ROLE_KEY=     ← Full admin access. Server-side only.
# DATABASE_URL=                  ← Direct DB connection. Server-side only.
# SMTP_PASSWORD=                 ← Email service credentials.
# PAYMENT_API_KEY=               ← Payment gateway secret.
# SMS_API_KEY=                   ← SMS service API key.
